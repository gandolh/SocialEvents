# Server configuration

# Required in production. In dev, an ephemeral secret is generated with a warning.
JWT_SECRET=

# SQLite database file path (default: ./data/socialevents.sqlite)
DATABASE_PATH=./data/socialevents.sqlite

# Server port
PORT=3001

# CORS origin for the client in dev (omit in single-origin prod)
CLIENT_ORIGIN=http://localhost:5173

# --- Optional integrations: leave blank to use mock implementations ---

# Weather (WeatherStack-compatible). Blank => mock weather.
WEATHER_API_KEY=

# SMTP for email invites. Blank => console/dev-capture transport.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="SocialEvents <no-reply@socialevents.local>"
