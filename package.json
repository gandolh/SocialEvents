{
  "name": "socialevents",
  "version": "1.0.0",
  "private": true,
  "description": "Internal company social-events planner (rebuild)",
  "workspaces": [
    "shared",
    "server",
    "client"
  ],
  "scripts": {
    "build:shared": "npm run build --workspace shared",
    "dev:server": "npm run dev --workspace server",
    "dev:client": "npm run dev --workspace client",
    "build": "npm run build --workspace shared && npm run build --workspace server && npm run build --workspace client",
    "typecheck": "tsc -b",
    "test": "npm run test --workspace server",
    "migrate": "npm run migrate --workspace server",
    "seed": "npm run seed --workspace server",
    "lint": "eslint ."
  },
  "devDependencies": {
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=20.11.0"
  }
}
