# Client configuration (Vite — only VITE_* vars are exposed to the browser)

# Google Maps browser key (PUBLIC). Blank => non-interactive map fallback.
VITE_MAPS_BROWSER_KEY=

# API base URL. Default same-origin "/api" (works with the dev proxy and
# single-origin prod). Override only if the API is on a different origin.
VITE_API_BASE_URL=/api
